{
  // Wrangler config for Cloudflare Workers + Static Assets.
  // We only deploy the pre-rendered static output in ./dist — never the repo root.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hotecholution",
  "compatibility_date": "2026-05-30",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
